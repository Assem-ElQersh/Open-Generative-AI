# Copy this file to .env.local (Next.js) or .env and fill in the values you
# need. Nothing here is required to run the app with the default MuAPI
# integration — end users provide their own MuAPI key at runtime via the
# Settings UI (stored client-side), not as a server environment variable.

# Optional: comma-separated list of extra hostnames the upload-binary proxy
# (app/api/upload-binary, app/api/v1/upload-binary) is allowed to forward
# pre-signed uploads to, in addition to the built-in Amazon S3 host patterns.
# Only set this if you run a self-hosted/alternate object storage backend
# behind MuAPI. See src/lib/uploadProxyTarget.js for the validation rules
# (HTTPS only; localhost/private IPs are always blocked).
# UPLOAD_PROXY_ALLOWED_HOSTS=my-bucket.example.com

# Optional: used only by scripts/test_minimax_provider.js to run a live
# smoke test against the MuAPI image-generation endpoint. Not read by the
# app itself. Get a key at https://muapi.ai/access-keys.
# MUAPI_KEY=
